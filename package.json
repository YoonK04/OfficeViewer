{
  "name": "office-viewer",
  "version": "0.1.1",
  "description": "로컬 Office 문서 통합 뷰어 (탐색기 + 탭/분할)",
  "main": "out/main/index.js",
  "author": "Ultivis",
  "license": "Beerware",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:dir": "electron-vite build && electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@univerjs/preset-sheets-core": "^0.25.1",
    "@univerjs/presets": "^0.25.1",
    "docx-preview": "^0.3.7",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "hwp.js": "^0.0.3",
    "luckyexcel": "^1.0.1",
    "pdfjs-dist": "^4.10.38",
    "pptx-preview": "^1.0.7"
  },
  "build": {
    "appId": "com.ultivis.officeviewer",
    "productName": "Office Viewer",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "ultivis-iot",
      "repo": "OfficeViewer"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Office Viewer"
    }
  }
}
